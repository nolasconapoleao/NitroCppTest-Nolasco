{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run",
            "type": "shell",
            "command": [
                "./run.sh"
            ]
        },
        {
            "label": "Make all",
            "type": "shell",
            "command": [
                "rm -rf build",
                "&& mkdir build",
                "&& cd build || exit",
                "&& cmake -DCMAKE_BUILD_TYPE=Debug  ..",
                "&& make all -j"
            ]
        },
        {
            "label": "Static analysis",
            "type": "shell",
            "command": [
                "if [[ ${file} =~ .(c|cpp|h|cc)$ ]]; then;",
                "  clang-format -i ${file};",
                "elif [[ ${file} =~ (CMakeLists.txt|.cmake) ]]; then;",
                "  cmake-format -i ${file};",
                "fi"
            ]
        },
    ]
}
